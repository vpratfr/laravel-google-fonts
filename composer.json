{
    "name": "vpratfr/laravel-google-fonts",
    "description": "Manage self-hosted Google Fonts in Laravel apps",
    "keywords": [
        "laravel",
        "laravel-google-fonts",
        "Google Fonts"
    ],
    "homepage": "https://github.com/vpratfr/laravel-google-fonts",
    "license": "MIT",
    "authors": [
        {
            "name": "Sébastien Girard",
            "role": "Developer"
        },
        {
            "name": "Vincent Mimoun-Prat",
            "role": "Developer"
        },
        {
            "name": "Spatie",
            "role": "Original author"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.3",
        "illuminate/contracts": "^12.0",
        "spatie/laravel-package-tools": "^1.7.0"
    },
    "require-dev": {
        "brianium/paratest": "^7.4",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "spatie/pest-plugin-snapshots": "^2.0",
        "spatie/phpunit-snapshot-assertions": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Spatie\\GoogleFonts\\": "src",
            "Spatie\\GoogleFonts\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Spatie\\GoogleFonts\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage-html coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Spatie\\GoogleFonts\\GoogleFontsServiceProvider"
            ],
            "aliases": {
                "GoogleFonts": "Spatie\\GoogleFonts\\GoogleFontsFacade"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
